<mxGeometry x="250" y="33" width="500" height="16" as="geometry"/>
</mxCell>
<mxCell id="66" value="&lt;font color=&quot;#D3D1C7&quot; style=&quot;font-size:11px&quot;&gt;&lt;b&gt;Calling Convention &amp;amp; ISA Info&lt;/b&gt;&lt;br&gt;ra(x1)=ret-addr | sp(x2)=stack-ptr(down) | a0-a7=args/retval | s0-s11=callee-saved | t0-t6=temp&lt;br&gt;lui+addi = %hi/%lo for 32b address construct | lw/sw offset(rs) = base+offset addressing&lt;br&gt;JAL: rd=PC+4, pc=target | JALR: rd=PC+4, pc=rs1+offset | NOP=addi x0,x0,0 | All 4B fixed&lt;br&gt;ALU zero flag drives conditional branches (beqz/bnez/beq/bne/bgt/ble/bgtu/bleu)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#444441;strokeColor=#B4B2A9;strokeWidth=1;fontFamily=Consolas;fontSize=12;align=center;verticalAlign=middle;arcSize=8;opacity=100;" vertex="1" parent="1">
<mxGeometry x="50" y="495" width="590" height="88" as="geometry"/>
</mxCell>
<mxCell id="67" value="&lt;font color=&quot;#FAF9F5&quot; style=&quot;font-size:11px&quot;&gt;&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;Solid lines = Data path (bus) | Dashed lines = Control signals&lt;br&gt;Green lines = ALU computation result | Orange lines = Branch logic&lt;br&gt;Colored blocks = Functional units (PC/IM/RF/ALU/DM/MMIO/CU)&lt;br&gt;x0 = hardwired zero (reads=0, writes ignored) | gp(x3)=global ptr | tp(x4)=thread ptr&lt;br&gt;ALU supports: add/sub/mul/div/rem/and/or/xor/sll/srl/sra | MULH = high 32b for overflow&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E1E1C;strokeColor=#3A3A35;strokeWidth=1;fontFamily=Consolas;fontSize=12;align=center;verticalAlign=middle;arcSize=8;opacity=100;" vertex="1" parent="1">
